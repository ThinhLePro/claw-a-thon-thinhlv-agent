# MCP Server — Juniper NETCONF Gateway
# Copy this to .env and fill in the values

# NETCONF credentials for connecting to Junos devices
NETCONF_USER=network-agent
NETCONF_PASSWORD=

# MCP server port
MCP_PORT=8000

# Path to shared device inventory JSON file
DEVICES_FILE=/app/shared/devices.json

# Command execution timeout (seconds)
COMMAND_TIMEOUT=60

# Command database paths (mounted via docker-compose)
OPERATION_COMMANDS_DB=/app/db/operation_commands.db
CONFIG_STATEMENTS_DB=/app/db/configuration_statements.db

# Git credentials for repository operations
GIT_USERNAME=
GIT_EMAIL=
GIT_PASSWORD=

# Prometheus and Loki URLs for monitoring
PROMETHEUS_URL=http://prometheus:9090
LOKI_URL=http://loki:3100

# Jira configuration (for propose_network_change and webhook)
JIRA_BASE_URL=
JIRA_USER_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=KAN

# Jira Webhook HMAC-SHA256 shared secret
JIRA_WEBHOOK_SECRET=

# Knowledge base URL (RAG server)
KNOWLEDGE_BASE_URL=http://rag-engine.local:8010
