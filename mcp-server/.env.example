# MCP Server — Juniper NETCONF Gateway
# Copy this to .env and fill in the values

# NETCONF credentials for connecting to Junos devices
NETCONF_USER=network-agent
NETCONF_PASSWORD=

# MCP server port
MCP_PORT=8000

# Path to shared device inventory JSON file
DEVICES_FILE=/app/shared/devices.json

# Git credentials for repository operations
GIT_USERNAME=
GIT_EMAIL=
GIT_PASSWORD=
