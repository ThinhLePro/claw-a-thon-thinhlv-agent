# DC Network Engineer Agent — Environment Variables
# Copy this to .env and fill in the values

# LLM Configuration (OpenAI-compatible endpoint)
LLM_BASE_URL=
LLM_MODEL=
LLM_API_KEY=

# GreenNode AgentBase Memory
MEMORY_ID=
MEMORY_STRATEGY_ID=default

# MCP Server URL (Juniper NETCONF Gateway)
# When running via docker-compose: http://mcp-server:8000/sse
# When MCP server is on a remote host: http://<ip>:8000/sse
MCP_SERVER_URL=http://49.213.77.221:8000/sse

# Telegram Bot (optional — leave empty to disable)
TELEGRAM_BOT_TOKEN=
